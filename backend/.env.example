# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Required: Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Required: Supabase Anonymous Key
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Required: Service Role Key (backend only — NEVER expose in browser / Vite)
# Must be the "service_role" secret from Supabase → Settings → API (JWT payload role = service_role).
# If you paste the anon key here by mistake, inserts hit RLS: "permission denied for table customer_orders".
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: direct Postgres connection for schema tooling (pg_dump, migration
# diffing) — a separate secret from the URL/keys above, which only work for the
# REST API and can't open a raw Postgres connection. Get from: Supabase dashboard
# → Project Settings → Database → Connection string → "URI" tab (pooler
# "Transaction" string, port 6543, for IPv4 compatibility).
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Backend Server Port (optional, defaults to 3000)
PORT=3000

# Google Maps API Key for Server-Side Requests
# IMPORTANT: This key should NOT have HTTP referrer restrictions
# Application restrictions: None (or IP restrictions if you have a static server IP)
# API restrictions: Restrict to Directions API, Roads API, Geocoding API, Places API
# Get from: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=your-server-side-api-key-here

# Alternative: Use GOOGLE_MAPS_SERVER_API_KEY if you prefer a different variable name
# GOOGLE_MAPS_SERVER_API_KEY=your-server-side-api-key-here

# Note: VITE_GOOGLE_MAPS_API_KEY can be used as fallback, but it may have referrer restrictions
# which will cause REQUEST_DENIED errors for server-side API calls

# Twilio Configuration for OTP
# Get these from: https://console.twilio.com/
# Required: Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Required: Verify Service SID (starts with VA)
# Create at: https://console.twilio.com/verify/services
TWILIO_SERVICE_SID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Razorpay Payment Gateway (for online payments)
# Use Test mode keys for development (Key Id starts with rzp_test_). Same API base URL as live.
# Dashboard: https://dashboard.razorpay.com/app/keys
# Test cards / UPI: https://razorpay.com/docs/payments/payments/test-card-upi-details/
# Webhooks: use a tunnel (e.g. ngrok) to POST to /api/payment/webhook; use the test webhook secret from the dashboard.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Webhook secret from Razorpay Dashboard → Webhooks → (your endpoint) → Secret.
# Required — without this, all incoming webhooks are rejected (payment status updates won't work).
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Resend (transactional email — order confirmations/status updates)
# Get an API key from: https://resend.com/api-keys
# Without this set, email sending is skipped (logged only) — same graceful-degradation pattern as Twilio above.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be on a domain verified in Resend (https://resend.com/domains). Falls back to Resend's
# shared onboarding@resend.dev sender if unset, which only works for testing to your own inbox.
RESEND_FROM_EMAIL=orders@yourdomain.com

# Optional CORS allowlist (comma-separated). If unset, any Origin is allowed (reflected) — same as a typical Railway setup.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
