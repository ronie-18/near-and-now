# Google Maps API Key (enable Directions API + Roads API in Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Direct Postgres connection for schema tooling (pg_dump, migration diffing) — a
# separate secret from the URL/keys above, which only work for the REST API.
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# → "URI" tab (pooler "Transaction" string, port 6543, for IPv4 compatibility).
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Browser API origin for production builds (usually your deployed site if /api is on the same host, e.g. Vercel).
# In Vite dev, HTTPS values are ignored for the base — the app uses same-origin /api and the dev proxy instead.
# NOT the Vite dev port (5173) and not used for the Vite proxy target (see VITE_API_PROXY_TARGET).
VITE_API_URL=https://your-app.vercel.app

# Vite dev only: URL the dev server proxies /api to (local Express). Defaults to http://127.0.0.1:3000 if unset.
# Set this to a staging API if you are not running the backend locally.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Optional: restrict CORS to listed origins (comma-separated). If unset, any browser Origin is allowed (reflected).
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
