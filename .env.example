# Google Maps API Key (enable Directions API + Roads API in Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Backend API URL (required for deployed site: set to your backend URL so OTP/login works, e.g. https://api.yoursite.com)
VITE_API_URL=http://localhost:3000

# Backend CORS — comma-separated browser origins (Express). Include local Vite + production domain(s).
ALLOWED_ORIGINS=http://localhost:5173,https://nearandnow.in,https://www.nearandnow.in
